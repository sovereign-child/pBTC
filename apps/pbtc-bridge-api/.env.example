PORT=3007
CORS_ORIGIN=*
BRIDGE_API_MODE=mock

# Guardian mint quorum settings
GUARDIAN_MIN_ACTIVE_FOR_MINT=1
GUARDIAN_HEARTBEAT_TTL_MS=120000

# Guardian heartbeat authentication.
# The heartbeat is a LIVENESS signal, NOT a mint authorization (real mint auth is
# the on-chain SPV proof). Each heartbeat must be HMAC-signed with the guardian's
# shared secret so a random caller can't report liveness / flip mintingAllowed.
# Format: comma-separated guardianId:secret pairs.
#   GUARDIAN_KEYS=guardian-a:CHANGE_ME_LONG_RANDOM_SECRET,guardian-b:ANOTHER_SECRET
# Leaving this empty disables auth and is ONLY allowed in BRIDGE_API_MODE=mock
# (a loud warning is logged). Any non-mock deployment MUST set GUARDIAN_KEYS.
GUARDIAN_KEYS=
# Max clock skew (ms) allowed on the signed heartbeat timestamp.
GUARDIAN_AUTH_MAX_SKEW_MS=300000

# Required when BRIDGE_API_MODE=upstream
UPSTREAM_BRIDGE_API_URL=

# Optional: sent as x-api-key header to upstream service
UPSTREAM_BRIDGE_API_KEY=

# Upstream resilience settings
UPSTREAM_TIMEOUT_MS=10000
UPSTREAM_MAX_RETRIES=2
UPSTREAM_RETRY_BASE_MS=250
UPSTREAM_CIRCUIT_FAILURE_THRESHOLD=5
UPSTREAM_CIRCUIT_OPEN_MS=30000

# Rate limiting (per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
