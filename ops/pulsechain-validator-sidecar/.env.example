# ===== Pulsechain / Bitcoin endpoints =====
PULSECHAIN_RPC_URL=https://rpc.v4.testnet.pulsechain.com
ELECTRUM_URL=wss://electrumx-server.test.tbtc.network:8443

# ===== Sidecar runtime =====
ENVIRONMENT=testnet
MONITOR_INTERVAL_SEC=90
DATA_DIR_PATH=/mnt/data

# ===== Guardian heartbeat to bridge API =====
GUARDIAN_HEARTBEAT_ENABLED=true
GUARDIAN_ID=
GUARDIAN_VERSION=monitoring-local
GUARDIAN_HEARTBEAT_INTERVAL_SEC=30
BRIDGE_API_HEARTBEAT_URL=http://host.docker.internal:3007/guardians/heartbeat

# ===== Maintainer fee/reimbursement routing =====
# EVM address used by the validator operator to receive maintainer transaction fee reimbursements.
TRANSACTION_FEE_RECIPIENT_ADDRESS=

# ===== Optional monitoring thresholds =====
LARGE_DEPOSIT_THRESHOLD_SAT=1000000000
LARGE_REDEMPTION_THRESHOLD_SAT=1000000000

# ===== Optional alert sinks =====
SENTRY_DSN=
DISCORD_WEBHOOK_URL=

# ===== Contract deployment export used by tests/smoke =====
# Relative to repo root when running local scripts.
CONTRACTS_DEPLOYMENT_EXPORT_FILE_PATH=solidity/export.pulsechain-testnet.json

# ===== Bitcoin keys for smoke test only (never share / never commit real keys) =====
WALLET_BITCOIN_WIF=
DEPOSITOR_BITCOIN_WIF=
