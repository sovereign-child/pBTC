# ─── pBTC Testnet Stack Configuration ─────────────────────────────────
# Copy this file to .env.testnet and fill in values before launching.
#
# Quick start (mock mode — no chain dependencies):
#   cp .env.testnet.example .env.testnet
#   docker compose -f docker-compose.testnet.yml --env-file .env.testnet up --build
#
# The defaults below are enough to run the full portal + API in mock mode.

# ─── Portal settings ─────────────────────────────────────────────────
PORTAL_PORT=8080
VITE_PULSECHAIN_CHAIN_ID=943
VITE_PULSECHAIN_RPC_URL=https://rpc.v4.testnet.pulsechain.com
VITE_PULSECHAIN_NETWORK_NAME=Pulsechain Testnet
VITE_PULSECHAIN_EXPLORER_BASE_URL=https://scan.v4.testnet.pulsechain.com
VITE_BTC_PRICE_USD=95000

# Set these once contracts are deployed on testnet:
VITE_PBTC_TOKEN_ADDRESS=
VITE_BANK_ADDRESS=
VITE_BRIDGE_ADDRESS=

# ─── Bridge API settings ─────────────────────────────────────────────
BRIDGE_API_PORT=3007
BRIDGE_API_MODE=mock
GUARDIAN_MIN_ACTIVE_FOR_MINT=1
GUARDIAN_HEARTBEAT_TTL_MS=120000

# ─── Bridge API URL (portal -> API wiring) ───────────────────────────
# For Docker: the portal is built with this baked in at build time.
# For local browser access, use localhost (default).
VITE_BRIDGE_API_URL=http://localhost:3007

# ─── Guardian heartbeat identity ─────────────────────────────────────
GUARDIAN_ID=testnet-tester
GUARDIAN_VERSION=docker-testnet
GUARDIAN_HEARTBEAT_INTERVAL_SEC=30

# ─── Monitoring sidecar (only used with --profile full) ──────────────
PULSECHAIN_RPC_URL=https://rpc.v4.testnet.pulsechain.com
ELECTRUM_URL=
TRANSACTION_FEE_RECIPIENT_ADDRESS=
MONITOR_INTERVAL_SEC=90
SENTRY_DSN=
DISCORD_WEBHOOK_URL=

# ─── Prometheus + Grafana (only used with --profile full) ─────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=pbtc-testnet

# ─── Upstream mode (advanced — leave blank for mock) ─────────────────
UPSTREAM_BRIDGE_API_URL=
UPSTREAM_BRIDGE_API_KEY=
